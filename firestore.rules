rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Since this is a school website, reading of results, students, etc. is public.
    // Making write restricted to Admin (User's email).
    function isAdmin() { 
      return request.auth != null && 
             request.auth.token.email == "tcbharat335@gmail.com";
    }

    match /students/{studentId} {
      allow read: if true; // Public list
      allow write: if isAdmin();
    }
    match /results/{resultId} {
      allow read: if true; // Public list
      allow write: if isAdmin();
    }
    match /teachers/{teacherId} {
      allow read: if true; // Public list
      allow write: if isAdmin();
    }
    match /admissions/{admissionId} {
      allow create: if true; // Public can submit application
      allow read, update, delete: if isAdmin();
    }
    match /gallery/{galleryItemId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /news/{newsItemId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /duas/{duaId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
